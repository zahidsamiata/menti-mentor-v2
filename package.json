{
  "name": "menti-mentor-v2",
  "version": "0.1.0",
  "private": true,
  "description": "Menti-Mentor SaaS monorepo — backend (submodule) + frontend",
  "scripts": {
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "lint:backend": "npm --prefix backend run lint",
    "lint:frontend": "npm --prefix frontend run lint",
    "build:backend": "npm --prefix backend run build",
    "build:frontend": "npm --prefix frontend run build",
    "test:backend": "npm --prefix backend test",
    "docker:up": "docker compose --env-file .env.compose.local up -d",
    "docker:down": "docker compose --env-file .env.compose.local down",
    "docker:build": "docker compose --env-file .env.compose.local build"
  }
}
